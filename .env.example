# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Groq (OpenAI-compatible endpoint) — SERVER-SIDE ONLY.
# Deliberately NOT prefixed EXPO_PUBLIC_: Expo inlines EXPO_PUBLIC_*
# vars into the client bundle at build time, which would leak this key
# to anyone who opens devtools or decompiles the app. It's read only by
# the Vercel serverless function at /api/groq.js, set as a regular
# (server) environment variable in the Vercel project settings — never
# put it in a client .env file that ships with the app.
GROQ_API_KEY=your-groq-api-key-here
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile

# Native (iOS/Android) builds only — point this at your deployed web
# origin so the app can reach /api/groq without a same-origin server to
# fall back to. Leave unset for local web dev and for Vercel itself
# (relative /api path resolves against the app's own origin there).
# EXPO_PUBLIC_API_BASE_URL=https://your-app.vercel.app

# Never commit the real .env file. See .gitignore.
