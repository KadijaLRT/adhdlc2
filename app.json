{
  "expo": {
    "name": "ADHD Life Coach",
    "slug": "adhd-life-coach",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "adhdlifecoach",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": { "image": "./assets/splash.png", "resizeMode": "contain", "backgroundColor": "#fafaf9" },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.adhdlifecoach.app",
      "infoPlist": { "UIViewControllerBasedStatusBarAppearance": true, "NSCameraUsageDescription": "Used only to scan a food barcode when logging what you ate — nothing is recorded or stored." }
    },
    "android": {
      "package": "com.adhdlifecoach.app",
      "adaptiveIcon": { "foregroundImage": "./assets/adaptive-icon.png", "backgroundColor": "#fafaf9" }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png",
      "name": "ADHD Life Coach",
      "shortName": "Aviva",
      "display": "standalone",
      "orientation": "portrait",
      "backgroundColor": "#fafaf9",
      "themeColor": "#fafaf9",
      "meta": {
        "apple-mobile-web-app-capable": "yes",
        "apple-mobile-web-app-status-bar-style": "black-translucent",
        "apple-mobile-web-app-title": "Aviva"
      }
    },
    "plugins": [
      "expo-router",
      ["expo-camera", { "cameraPermission": "Used only to scan a food barcode when logging what you ate — nothing is recorded or stored." }]
    ],
    "experiments": { "typedRoutes": true }
  }
}
